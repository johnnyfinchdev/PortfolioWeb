---
import { site } from '@data/site';
import { Icon } from 'astro-icon/components';
---

<div class="flex items-center gap-1">
  {
    site.contact.map((row) => (
  <a
    href={row.link}
    class="subtle-link inline-flex h-9 w-9 items-center justify-center rounded"
    target="_blank"
    rel="noreferrer"
    aria-label="GitHub"
  >
    <Icon name=`ph:${row.icon}` class="h-6 w-6" />
  </a>
  ))
  }
</div>
